<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_purchase_order_form_qne" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit.qne.connector</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_qne_push_purchase_order" type="object"
                        string="Push to QNE"
                        class="oe_stat_button"
                        icon="fa-cloud-upload">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Push to QNE</span>
                    </div>
                </button>
            </xpath>
            <xpath expr="//sheet" position="inside">
                <group string="QNE Sync">
                    <field name="qne_po_id"/>
                    <field name="qne_last_push_date"/>
                    <field name="qne_push_status"/>
                    <field name="qne_push_message" invisible="qne_push_status != 'error'"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
